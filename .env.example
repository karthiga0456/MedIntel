# App
APP_NAME=MedIntel
ENV=development
DEBUG=true

# Module 1: Knowledge Assistant (LLM)
LLM_PROVIDER=llama3
LLM_MODEL_PATH=./models/llama-3-8b-instruct.gguf
LLM_API_BASE=

# Module 2: Healthcare RAG
VECTOR_DB_PATH=./data/vector_store
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Module 3: Outbreak Prediction
OUTBREAK_MODEL_PATH=./data/models/outbreak_lstm.h5

# Module 4: Health Worker Portal
LOCAL_DB_URL=sqlite:///./data/local_db/health_worker.db

# Security
SECRET_KEY=change-me-in-production
